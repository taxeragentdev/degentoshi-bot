# Market data: mainnet = gerçek piyasa fiyatları (varsayılan).
# Testnet fiyatları piyasadan farklıdır; sadece HL test ortamı için kullanın.
# HYPERLIQUID_API_URL=https://api.hyperliquid-testnet.xyz

HYPERLIQUID_API_URL=https://api.hyperliquid.xyz

EXCHANGE=hyperliquid

SCAN_INTERVAL_MS=60000
MAX_OPEN_TRADES=3
RISK_PER_TRADE=0.01

# Aynı coin için tekrar sinyal (ms). 4 saat = 14400000
SIGNAL_COOLDOWN_MS=14400000

# Telegram: sadece HIGH veya MEDIUM+HIGH bildir
# TELEGRAM_MIN_CONFIDENCE=MEDIUM
TELEGRAM_MIN_CONFIDENCE=HIGH

# Coins (Hyperliquid mainnet perp isimleri: BASE/USDC)
COINS=BTC/USDC,ETH/USDC,SOL/USDC,DOGE/USDC

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

AUTO_TRADE=false
ACTIVE_AGENTS=raichu
