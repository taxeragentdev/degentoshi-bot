# Market data (Hyperliquid mainnet = gerçek fiyatlar)
HYPERLIQUID_API_URL=https://api.hyperliquid.xyz

EXCHANGE=hyperliquid

SCAN_INTERVAL_MS=60000
MAX_OPEN_TRADES=3
RISK_PER_TRADE=0.01
# SL–entry minimum mesafe (örn. 0.01 = %1). Düşük ATR'de çok sıkı SL önlenir.
# MIN_STOP_DISTANCE_PCT=0.008
# MAX_STOP_DISTANCE_PCT=0.08

SIGNAL_COOLDOWN_MS=14400000

TELEGRAM_MIN_CONFIDENCE=HIGH
# AUTO_TRADE_MIN_CONFIDENCE=HIGH

COINS=BTC/USDC,ETH/USDC,SOL/USDC,DOGE/USDC

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

AUTO_TRADE=false
# Otomatik emirde hangi agentlar: virgülle. Hepsini kapatmak için AUTO_TRADE=false veya ACTIVE_AGENTS=
ACTIVE_AGENTS=raichu,venom
# Otomatik emir tutarı (USDC): max(min, min(bakiye*fraction, max)), bakiyeyi aşmaz
# AUTO_TRADE_MIN_NOTIONAL_USD=15
# AUTO_TRADE_BALANCE_FRACTION=0.2
# AUTO_TRADE_MAX_POSITION_USD=100

# Sinyal kaldıracı: MEDIUM → LEVERAGE_MEDIUM, HIGH → LEVERAGE_HIGH; skor ≥ LEVERAGE_VERY_HIGH_MIN_SCORE ise VERY_HIGH
# (Koşul skoru tipik aralık ~4–8; HIGH eşiği CONFIG.thresholds.confidence.high ile aynı mantık)
# LEVERAGE_LOW=1
# LEVERAGE_MEDIUM=3
# LEVERAGE_HIGH=5
# LEVERAGE_VERY_HIGH=10
# LEVERAGE_VERY_HIGH_MIN_SCORE=7

# --- Degen Claw / Virtuals ACP (işlem açma) ---
# pair alanı her zaman sadece baz coin (BTC, HYPE) — HYPE/USDC gönderilmez
# Güncel: https://claw-api.virtuals.io + POST /acp/jobs + x-api-key (Bearer değil)
# DEGEN_ACP_API_URL=https://claw-api.virtuals.io
# ACP_API_URL aynı anlamda (telegram-degen-bot ile uyumlu)
# İsteğe bağlı: ACP_BUILDER_CODE=

DEGEN_CLAW_USERS_API_URL=https://dgclaw-app-production.up.railway.app/users
# (Eski dokümantasyon: https://dgclaw-trader.virtuals.io/users/... — env ile override edilebilir)

# --- Degen Claw v2: doğrudan Hyperliquid (dgclaw-skill trade.ts ile aynı mantık) ---
# Agent alias büyük harf: raichu → HL_RAICHU_*. Tanımlıysa ACP perp_trade yerine HL kullanılır.
# HL_RAICHU_API_WALLET_KEY=0x...
# HL_RAICHU_MASTER_ADDRESS=0x...
# Ayrıntı: docs/DEGEN_CLAW_V2.md

# Railway "fetch failed" / DNS: NODE_OPTIONS=--dns-result-order=ipv4first
