# Exchange API Configuration (optional - bot uses public endpoints only)
# EXCHANGE=binance
# API_KEY=your_api_key_here
# API_SECRET=your_api_secret_here

# Bot Configuration
SCAN_INTERVAL_MS=60000
MAX_OPEN_TRADES=3
RISK_PER_TRADE=0.01
CAPITAL=10000

# Coins to monitor (comma-separated)
COINS=BTC/USDT,ETH/USDT,SOL/USDT,BNB/USDT,XRP/USDT,ADA/USDT,DOGE/USDT,MATIC/USDT,DOT/USDT,AVAX/USDT,LINK/USDT,UNI/USDT,ATOM/USDT,LTC/USDT,NEAR/USDT,APT/USDT,ARB/USDT,OP/USDT,INJ/USDT,TIA/USDT

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Auto-Trade Configuration (optional)
AUTO_TRADE=false
AUTO_TRADE_AGENT=raichu
